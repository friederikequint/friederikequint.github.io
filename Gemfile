# Gemfile
source "https://rubygems.org"

# Pin to the same release GitHub Pages uses in your log (v232)
gem "github-pages", "~> 232", group: :jekyll_plugins

# Local dev only (won't be installed on GitHub Pages)
group :development do
  gem "webrick", "~> 1.8"
end

# Optional Windows helper for local dev
gem "wdm", "~> 0.1.0", platforms: [:mingw, :x64_mingw, :mswin]
